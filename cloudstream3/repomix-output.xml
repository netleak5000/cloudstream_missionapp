                try {
                    enterPictureInPictureMode(PictureInPictureParams.Builder().build())
                } catch (_: Exception) {
                    // Use fallback just in case
                    @Suppress("DEPRECATION")
                    enterPictureInPictureMode()
                }
            } else {
                if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.N) {
                    @Suppress("DEPRECATION")
                    enterPictureInPictureMode()
                }
            }
        } catch (e: Exception) {
            logError(e)
        }
    }

