    private fun onAllPluginsLoaded(success: Boolean = false) {
        ioSafe {
            pluginsLock.withLock {
                synchronized(allProviders) {
                    try {
                        // Build a list of cloned/custom providers (if any)
                        val newProviders = mutableListOf<MainAPI>()
                        getKey<Array<SettingsGeneral.CustomSite>>(USER_PROVIDER_API)?.forEach { custom ->
                            allProviders.firstOrNull { it.javaClass.simpleName == custom.parentJavaClass }?.let {
                                newProviders.add(it.javaClass.getDeclaredConstructor().newInstance().apply {
                                    name = custom.name
                                    lang = custom.lang
                                    mainUrl = custom.url.trimEnd('/')
                                    canBeOverridden = false
                                })
                            }
                        }

                        // Merge existing providers with new ones and dedupe by stable key
                        val mergedProviders = (allProviders + newProviders).distinctBy {
                            "${it.lang}-${it.name}-${it.mainUrl}-${it.javaClass.name}"
                        }

                        // Replace allProviders content with the merged unique list
                        allProviders.clear()
                        allProviders.addAll(mergedProviders)

                        // Update the apis mapping and invalidate cached map
                        apis = allProviders
                        APIHolder.apiMap = null

                        Log.d("PluginLoader", "Loaded ${allProviders.size} unique plugins.")
                    } catch (e: Exception) {
                        logError(e)
                    }
                }
            }

            // Refresh UI after plugins are fully loaded
            main {
                refreshSources()
            }
        }
    }

