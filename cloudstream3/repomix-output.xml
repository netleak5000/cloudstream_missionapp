                            getPixels(TypedValue.COMPLEX_UNIT_SP, 25.0f).toFloat(),
                            Cue.TEXT_SIZE_TYPE_ABSOLUTE
                        )
                        .setText(context.getString(R.string.subtitles_example_text))
                        .build()
                )
            )
        }
    }
}
